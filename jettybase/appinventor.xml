<?xml version="1.0"  encoding="ISO-8859-1"?>
<!DOCTYPE Configure PUBLIC "-//Jetty//Configure//EN" "http://www.eclipse.org/jetty/configure_9_0.dtd">

<Configure class="org.eclipse.jetty.webapp.WebAppContext">
  <Set name="contextPath">/</Set>
  <Set name="war">appinventor.war</Set>
<!--  <Set name="war"><SystemProperty name="appinventor.root"/>/appinventor/appengine/build/war</Set> -->

  <Call name="setInitParameter">
    <Arg>org.eclipse.jetty.servlet.MaxAge</Arg>
    <Arg>-1</Arg>
  </Call>

  <Call class="java.lang.System" name="setProperty">
    <Arg>require.tos</Arg>
    <Arg>false</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>auth.usegoogle</Arg>
    <Arg>false</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>auth.uselocal</Arg>
    <Arg>true</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>localauth.mailserver</Arg>
    <Arg>https://osiris.mit.edu/passmail/</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>localauth.mailserver.password</Arg>
    <Arg>secret123</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>motd.check.interval.secs</Arg>
    <Arg>0</Arg>
  </Call>

  <Call class="java.lang.System" name="setProperty">
    <Arg>library.url</Arg>
    <Arg>http://appinventor.mit.edu/explore/library</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>get_started.url</Arg>
    <Arg>http://appinventor.mit.edu/explore/get-started</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>tutorials.url</Arg>
    <Arg>http://appinventor.mit.edu/explore/ai2/tutorials</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>troubleshooting.url</Arg>
    <Arg>http://appinventor.mit.edu/explore/ai2/support/troubleshooting</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>forums.url</Arg>
    <Arg>https://groups.google.com/forum/#!forum/mitappinventortest</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>feedback.url</Arg>
    <Arg>http://something.example.com</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>release.notes.url</Arg>
    <Arg>http://appinventor.mit.edu/ai2/ReleaseNotes.html</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>tos.url</Arg>
    <Arg>/about/termsofservice.html</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>logo.url</Arg>
    <Arg>http://appinventor.mit.edu</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>guide.url</Arg>
    <Arg>http://appinventor.mit.edu/explore/library</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>reference.components.url</Arg>
    <Arg>/reference/components/</Arg>
  </Call>

 <Get name="sessionHandler">
     <Set name="sessionManager">
         <New class="org.eclipse.jetty.server.session.HashSessionManager">
           <Set name="sessionCookie">AppInventorId</Set>
           <Set name="lazyLoad">true</Set>
           <Set name="storeDirectory"><SystemProperty name="storage.root"/>/SESSIONS</Set>
           <Set name="scavengePeriod">600</Set>
           <Set name="savePeriod">300</Set>
         </New>
     </Set>
  </Get>

</Configure>
