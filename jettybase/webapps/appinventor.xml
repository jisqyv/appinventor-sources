<?xml version="1.0"  encoding="ISO-8859-1"?>
<!DOCTYPE Configure PUBLIC "-//Jetty//Configure//EN" "http://www.eclipse.org/jetty/configure_9_0.dtd">

<Configure class="org.eclipse.jetty.webapp.WebAppContext">
  <Set name="contextPath">/</Set>
  <Set name="war"><SystemProperty name="appinventor.root"/>/appinventor/appengine/build/war</Set>
  <Call class="java.lang.System" name="setProperty">
    <Arg>auth.usegoogle</Arg>
    <Arg>false</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>auth.uselocal</Arg>
    <Arg>true</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>localauth.mailserver</Arg>
    <Arg>https://osiris.mit.edu/passmail/</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>localauth.mailserver.password</Arg>
    <Arg>secret123</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>storage.root</Arg>
    <Arg>/var/tmp/STORE</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>motd.check.interval.secs</Arg>
    <Arg>0</Arg>
  </Call>
  <Call class="java.lang.System" name="setProperty">
    <Arg>root.path</Arg>
    <Arg><SystemProperty name="appinventor.root"/>/appinventor/appengine/build/war/</Arg>
  </Call>
</Configure>
